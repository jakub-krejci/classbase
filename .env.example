# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git — it is already in .gitignore.

# ── Supabase ─────────────────────────────────────────
# Find both values in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase Service Role (server-only, never expose to browser) ──
# Find in: Supabase Dashboard -> Project Settings -> API -> service_role key
# Add this to Vercel environment variables (NOT prefixed with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AI Tutor (Google Gemini - free tier)
GEMINI_API_KEY=your_gemini_api_key_here
